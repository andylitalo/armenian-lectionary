# Keep the image small and avoid shipping dev-only / git-ignored assets.
venv/
dev/
tests/
reports/
docs/
.git/
.gitignore
__pycache__/
**/__pycache__/
.pytest_cache/
*.log
*.pyc
.DS_Store
# NOTE: README.md is intentionally NOT ignored — pyproject.toml's `readme` field
# references it, so `pip install .` needs it in the build context.
# The armenian_lectionary/ package (engine + bundled data) must also be shipped.
